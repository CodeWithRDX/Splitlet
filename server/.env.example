# Server Connection
PORT=5001

# MySQL Database Configuration
# Set DB_HOST=db when running inside docker-compose, or localhost for local testing
DB_HOST=db
DB_PORT=3306
DB_USER=splitlet_user
DB_PASSWORD=splitlet_password
DB_NAME=splitlet

# JWT Configuration
JWT_SECRET=splitlet_super_secret_jwt_key_2026

# Frontend Client URL
CLIENT_URL=http://localhost:3000

# SMTP / Nodemailer Email Settings (Optional)
# If left blank, Nodemailer operates in log-only mock console mode
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=noreply@splitlet.com

# Google OAuth 2.0 Credentials (Optional)
# If left blank, server defaults to developer mock OAuth bypass
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/oauth/google/callback
